# Base URL of your Canvas LMS instance (no trailing slash)
EPORTFOLIO_ARCHIVER_CANVAS_URL=https://your-institution.instructure.com

# Username of the admin account used to log in and masquerade as ePortfolio owners
EPORTFOLIO_ARCHIVER_CANVAS_USERNAME=eportfolioarchiver

# Password for the admin account
EPORTFOLIO_ARCHIVER_CANVAS_PASSWORD=your_password

# Canvas API token for the admin account (required for restore/delete of deleted ePortfolios)
# Generate one in Canvas: Account > Settings > New Access Token
EPORTFOLIO_ARCHIVER_CANVAS_API_TOKEN=your_api_token

# Path to the ePortfolios CSV export downloaded from Canvas
EPORTFOLIO_ARCHIVER_CSV_PATH=eportfolio_list.csv

# Directory where downloaded ZIP files will be saved, organized by user
EPORTFOLIO_ARCHIVER_EXPORT_DIR=downloads

# Maximum time to wait for a single export ZIP to download before marking it as an error (milliseconds)
EPORTFOLIO_ARCHIVER_DOWNLOAD_TIMEOUT_MS=600000
